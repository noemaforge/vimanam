{
  "swagger": "2.0",
  "info": {
    "title": "Multi Auth Legacy API",
    "version": "1.0.0"
  },
  "tags": [{ "name": "Pets", "description": "Pet operations" }],
  "paths": {
    "/pets": {
      "get": {
        "tags": ["Pets"],
        "summary": "List pets",
        "operationId": "Pets_ListPets",
        "responses": {
          "200": { "description": "A list of pets" }
        }
      }
    }
  },
  "securityDefinitions": {
    "zebraAuth": {
      "type": "oauth2",
      "description": "Zebra OAuth2"
    },
    "apiKey": {
      "type": "apiKey",
      "name": "api_key",
      "in": "header",
      "description": "API key auth"
    },
    "middleAuth": {
      "type": "basic",
      "description": "Basic auth"
    }
  }
}
